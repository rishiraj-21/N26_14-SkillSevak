# SkillSevak Environment Configuration
# Copy this file to .env and update values for your environment

# =============================================================================
# SECURITY
# =============================================================================
# IMPORTANT: Generate a new secret key for production!
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# =============================================================================
# DATABASE
# =============================================================================
# Option 1: SQLite (for development/testing only)
USE_SQLITE=True

# Option 2: PostgreSQL (recommended for production)
# Set USE_SQLITE=False and configure these:
# DB_NAME=skillsevak
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_HOST=localhost
# DB_PORT=5432

# Option 3: Use DATABASE_URL (for Heroku, Railway, etc.)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# =============================================================================
# REDIS (for caching and Celery)
# =============================================================================
REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# GOOGLE OAUTH (for "Sign in with Google")
# =============================================================================
# Get these from Google Cloud Console:
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add authorized redirect URI: http://localhost:8000/accounts/google/login/callback/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# ANN MODEL
# =============================================================================
# Set to False to always use weighted average formula instead of trained ANN
USE_ANN_MODEL=True

# =============================================================================
# ASYNC PROCESSING (Phase 6)
# =============================================================================
# Set to True to enable background processing with Celery
# Requires Redis running: redis-server
# Requires Celery worker: celery -A neuralnetwork worker -l info
USE_ASYNC_PROCESSING=False
