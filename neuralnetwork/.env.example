# SkillSevak Environment Configuration
# Copy this file to .env and update values for your environment

# =============================================================================
# SECURITY (REQUIRED FOR PRODUCTION)
# =============================================================================
# Generate a new secret key for production:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# =============================================================================
# DATABASE (Production uses PostgreSQL per PRD.md)
# =============================================================================
# Leave empty to use SQLite (development)
# For PostgreSQL: postgres://user:password@host:port/database
DATABASE_URL=

# =============================================================================
# CELERY & REDIS (Phase 6 - Background Tasks)
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/1
